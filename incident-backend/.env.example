# ─── Spring Boot Backend ───────────────────────────────────────────────────────
# The live deployed backend we poll for logs
BACKEND_URL=https://hackathonps.onrender.com

# ─── Claude AI ─────────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── ChromaDB (RAG vector store) ───────────────────────────────────────────────
# Run: docker-compose up chromadb  (or use local ChromaDB)
CHROMA_URL=http://localhost:8000

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Log Polling ───────────────────────────────────────────────────────────────
# How often to fetch new logs from the Spring Boot backend (milliseconds)
POLL_INTERVAL=20000

# ─── Automation: Slack ─────────────────────────────────────────────────────────
# Create an Incoming Webhook in your Slack workspace settings
SLACK_WEBHOOK_URL=your_slack_webhook

# ─── Automation: GitHub ────────────────────────────────────────────────────────
# Personal access token with repo:issues scope
GITHUB_TOKEN=your_github_token
# Format: owner/repository-name
GITHUB_REPO=harshaldhanewar/HackathonPS/
